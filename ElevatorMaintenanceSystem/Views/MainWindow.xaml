<Window x:Class="ElevatorMaintenanceSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:ElevatorMaintenanceSystem.Models"
        xmlns:views="clr-namespace:ElevatorMaintenanceSystem.Views"
        mc:Ignorable="d"
        Title="Elevator Maintenance System"
        Width="1440"
        Height="900"
        MinWidth="1180"
        MinHeight="760"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#17324D"
                Padding="28,22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Elevator Maintenance Management System"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,6,0,0"
                               Text="Dispatch office workspace for elevator and technician data."
                               Foreground="#D4E2F0"
                               FontSize="14" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#24496D"
                        CornerRadius="10"
                        Padding="18,10"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Connection Status"
                                   Foreground="#D4E2F0"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding ConnectionStatus}"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="20"
                Padding="20"
                Background="White"
                CornerRadius="18"
                BorderBrush="#D8E1EA"
                BorderThickness="1">
            <TabControl Background="Transparent"
                        BorderThickness="0">
                <TabItem Header="Elevators">
                    <Grid Margin="0,14,0,0"
                          DataContext="{Binding ElevatorManagement}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*" />
                            <ColumnDefinition Width="26" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="18"
                                Background="#F7FAFD"
                                BorderBrush="#D9E3EC"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="Elevator Profiles"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#17324D" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="Select an elevator to edit, or create a new inactive record for cleanup and testing."
                                                   Foreground="#5F7184"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right"
                                            MinWidth="110"
                                            Padding="14,8"
                                            Margin="12,0,0,0"
                                            Command="{Binding LoadCommand}"
                                            Content="Refresh" />
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,14,0,10"
                                           Text="{Binding StatusMessage}"
                                           Foreground="#2F5D85"
                                           FontWeight="SemiBold" />

                                <DataGrid Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding Elevators}"
                                          SelectedItem="{Binding SelectedElevator, Mode=TwoWay}"
                                          SelectionMode="Single"
                                          GridLinesVisibility="Horizontal"
                                          RowHeaderWidth="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name"
                                                            Width="1.2*"
                                                            Binding="{Binding Name}" />
                                        <DataGridTextColumn Header="Address"
                                                            Width="1.8*"
                                                            Binding="{Binding Address}" />
                                        <DataGridTextColumn Header="Building"
                                                            Width="*"
                                                            Binding="{Binding BuildingName}" />
                                        <DataGridTextColumn Header="Floor"
                                                            Width="0.7*"
                                                            Binding="{Binding FloorLabel}" />
                                        <DataGridTextColumn Header="Manufacturer"
                                                            Width="*"
                                                            Binding="{Binding Manufacturer}" />
                                        <DataGridTextColumn Header="Installed"
                                                            Width="0.9*"
                                                            Binding="{Binding InstallationDate, StringFormat=d}" />
                                        <DataGridCheckBoxColumn Header="Active"
                                                                Width="0.7*"
                                                                Binding="{Binding IsActive}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="18"
                                Background="#FCFDFE"
                                BorderBrush="#D9E3EC"
                                BorderThickness="1"
                                CornerRadius="14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Elevator Editor"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="#17324D" />
                                    <TextBlock Margin="0,4,0,18"
                                               Text="Create, update, or remove inactive elevator records with GPS coordinates."
                                               Foreground="#5F7184"
                                               TextWrapping="Wrap" />

                                    <UniformGrid Columns="2"
                                                 Margin="0,0,0,14">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Name" FontWeight="SemiBold" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Manufacturer" FontWeight="SemiBold" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding Manufacturer, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <TextBlock Text="Address" FontWeight="SemiBold" />
                                    <TextBox Margin="0,6,0,14"
                                             Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" />

                                    <UniformGrid Columns="2"
                                                 Margin="0,0,0,14">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Building" FontWeight="SemiBold" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding BuildingName, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Floor" FontWeight="SemiBold" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding FloorLabel, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <UniformGrid Columns="2"
                                                 Margin="0,0,0,14">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Installation Date" FontWeight="SemiBold" />
                                            <DatePicker Margin="0,6,0,0"
                                                        SelectedDate="{Binding InstallationDate, Mode=TwoWay}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Active" FontWeight="SemiBold" />
                                            <CheckBox Margin="0,10,0,0"
                                                      IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                      Content="Elevator is active" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <UniformGrid Columns="2"
                                                 Margin="0,0,0,18">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Latitude" FontWeight="SemiBold" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding Latitude, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Longitude" FontWeight="SemiBold" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding Longitude, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <WrapPanel ItemHeight="40"
                                               ItemWidth="124">
                                        <Button Margin="0,0,12,12"
                                                Padding="14,8"
                                                Command="{Binding SaveCommand}"
                                                Content="Create" />
                                        <Button Margin="0,0,12,12"
                                                Padding="14,8"
                                                Command="{Binding UpdateCommand}"
                                                Content="Update" />
                                        <Button Margin="0,0,12,12"
                                                Padding="14,8"
                                                Command="{Binding DeleteCommand}"
                                                Content="Delete Inactive" />
                                        <Button Margin="0,0,12,12"
                                                Padding="14,8"
                                                Command="{Binding ResetCommand}"
                                                Content="Reset" />
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Workers">
                    <Grid Margin="0,14,0,0"
                          DataContext="{Binding WorkerManagement}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*" />
                            <ColumnDefinition Width="26" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="18"
                                Background="#F7FAFD"
                                BorderBrush="#D9E3EC"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="Worker Profiles"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#17324D" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="Manage contact details, technician skills, availability, and manual GPS updates."
                                                   Foreground="#5F7184"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right"
                                            MinWidth="110"
                                            Padding="14,8"
                                            Margin="12,0,0,0"
                                            Command="{Binding LoadCommand}"
                                            Content="Refresh" />
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,14,0,10"
                                           Text="{Binding StatusMessage}"
                                           Foreground="#2F5D85"
                                           FontWeight="SemiBold" />

                                <DataGrid Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding Workers}"
                                          SelectedItem="{Binding SelectedWorker, Mode=TwoWay}"
                                          SelectionMode="Single"
                                          GridLinesVisibility="Horizontal"
                                          RowHeaderWidth="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Full Name"
                                                            Width="1.2*"
                                                            Binding="{Binding FullName}" />
                                        <DataGridTextColumn Header="Email"
                                                            Width="1.5*"
                                                            Binding="{Binding Email}" />
                                        <DataGridTextColumn Header="Phone"
                                                            Width="*"
                                                            Binding="{Binding PhoneNumber}" />
                                        <DataGridTextColumn Header="Skills"
                                                            Width="1.4*"
                                                            Binding="{Binding Skills}" />
                                        <DataGridTextColumn Header="Availability"
                                                            Width="0.9*"
                                                            Binding="{Binding AvailabilityStatus}" />
                                        <DataGridTextColumn Header="Latitude"
                                                            Width="0.9*"
                                                            Binding="{Binding Location.Coordinates.Latitude, StringFormat=F5}" />
                                        <DataGridTextColumn Header="Longitude"
                                                            Width="0.9*"
                                                            Binding="{Binding Location.Coordinates.Longitude, StringFormat=F5}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="18"
                                Background="#FCFDFE"
                                BorderBrush="#D9E3EC"
                                BorderThickness="1"
                                CornerRadius="14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Worker Editor"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="#17324D" />
                                    <TextBlock Margin="0,4,0,18"
                                               Text="Create or update a technician, then use manual location updates for map-ready dispatch data."
                                               Foreground="#5F7184"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="Full Name" FontWeight="SemiBold" />
                                    <TextBox Margin="0,6,0,14"
                                             Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" />

                                    <UniformGrid Columns="2"
                                                 Margin="0,0,0,14">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Email" FontWeight="SemiBold" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Phone" FontWeight="SemiBold" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <TextBlock Text="Skills (comma-separated)" FontWeight="SemiBold" />
                                    <TextBox Margin="0,6,0,14"
                                             Text="{Binding SkillsText, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Text="Availability" FontWeight="SemiBold" />
                                    <ComboBox Margin="0,6,0,14"
                                              SelectedValue="{Binding AvailabilityStatus, Mode=TwoWay}"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Tag="{x:Static models:WorkerAvailabilityStatus.Available}" Content="Available" />
                                        <ComboBoxItem Tag="{x:Static models:WorkerAvailabilityStatus.Assigned}" Content="Assigned" />
                                        <ComboBoxItem Tag="{x:Static models:WorkerAvailabilityStatus.Unavailable}" Content="Unavailable" />
                                    </ComboBox>

                                    <UniformGrid Columns="2"
                                                 Margin="0,0,0,18">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Latitude" FontWeight="SemiBold" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding Latitude, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Longitude" FontWeight="SemiBold" />
                                            <TextBox Margin="0,6,0,0"
                                                     Text="{Binding Longitude, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <WrapPanel ItemHeight="40"
                                               ItemWidth="124">
                                        <Button Margin="0,0,12,12"
                                                Padding="14,8"
                                                Command="{Binding SaveCommand}"
                                                Content="Create" />
                                        <Button Margin="0,0,12,12"
                                                Padding="14,8"
                                                Command="{Binding UpdateCommand}"
                                                Content="Update" />
                                        <Button Margin="0,0,12,12"
                                                Padding="14,8"
                                                Command="{Binding UpdateLocationCommand}"
                                                Content="Update Location" />
                                        <Button Margin="0,0,12,12"
                                                Padding="14,8"
                                                Command="{Binding DeactivateCommand}"
                                                Content="Deactivate" />
                                        <Button Margin="0,0,12,12"
                                                Padding="14,8"
                                                Command="{Binding ResetCommand}"
                                                Content="Reset" />
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Tickets">
                    <Grid Margin="0,14,0,0"
                          DataContext="{Binding TicketManagement}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.6*" />
                            <ColumnDefinition Width="26" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="18"
                                Background="#F7FAFD"
                                BorderBrush="#D9E3EC"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="Ticket Workflow"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#17324D" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="Track ticket lifecycle, worker assignment, and audit history from one workspace."
                                                   Foreground="#5F7184"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right"
                                            MinWidth="110"
                                            Padding="14,8"
                                            Margin="12,0,0,0"
                                            Command="{Binding LoadCommand}"
                                            Content="Refresh" />
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,14,0,10"
                                           Text="{Binding StatusMessage}"
                                           Foreground="#2F5D85"
                                           FontWeight="SemiBold" />

                                <DataGrid Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding TicketRows}"
                                          SelectedItem="{Binding SelectedTicketRow, Mode=TwoWay}"
                                          SelectionMode="Single"
                                          GridLinesVisibility="Horizontal"
                                          RowHeaderWidth="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Description"
                                                            Width="1.7*"
                                                            Binding="{Binding Description}" />
                                        <DataGridTextColumn Header="Issue"
                                                            Width="*"
                                                            Binding="{Binding IssueType}" />
                                        <DataGridTextColumn Header="Priority"
                                                            Width="0.9*"
                                                            Binding="{Binding Priority}" />
                                        <DataGridTextColumn Header="Status"
                                                            Width="0.9*"
                                                            Binding="{Binding Status}" />
                                        <DataGridTextColumn Header="Requested"
                                                            Width="1.1*"
                                                            Binding="{Binding RequestedDate, StringFormat=g}" />
                                        <DataGridTextColumn Header="Assigned Worker"
                                                            Width="1.2*"
                                                            Binding="{Binding AssignedWorkerDisplay}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="18"
                                Background="#FCFDFE"
                                BorderBrush="#D9E3EC"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Ticket Editor"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#17324D" />
                                <TextBlock Grid.Row="1"
                                           Margin="0,4,0,14"
                                           Text="Create and manage ticket details, assignments, status changes, and audit review."
                                           Foreground="#5F7184"
                                           TextWrapping="Wrap" />

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Elevator" FontWeight="SemiBold" />
                                    <ComboBox Margin="0,6,0,10"
                                              ItemsSource="{Binding Elevators}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding SelectedElevatorId, Mode=TwoWay}" />

                                    <TextBlock Text="Description" FontWeight="SemiBold" />
                                    <TextBox Margin="0,6,0,10"
                                             Height="48"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <UniformGrid Grid.Row="3"
                                             Columns="2"
                                             Margin="0,0,0,10">
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Issue Type" FontWeight="SemiBold" />
                                        <ComboBox Margin="0,6,0,0"
                                                  SelectedValue="{Binding IssueType, Mode=TwoWay}"
                                                  SelectedValuePath="Tag">
                                            <ComboBoxItem Tag="{x:Static models:TicketIssueType.Mechanical}" Content="Mechanical" />
                                            <ComboBoxItem Tag="{x:Static models:TicketIssueType.Electrical}" Content="Electrical" />
                                            <ComboBoxItem Tag="{x:Static models:TicketIssueType.Safety}" Content="Safety" />
                                            <ComboBoxItem Tag="{x:Static models:TicketIssueType.Inspection}" Content="Inspection" />
                                            <ComboBoxItem Tag="{x:Static models:TicketIssueType.Entrapment}" Content="Entrapment" />
                                            <ComboBoxItem Tag="{x:Static models:TicketIssueType.Other}" Content="Other" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Priority" FontWeight="SemiBold" />
                                        <ComboBox Margin="0,6,0,0"
                                                  SelectedValue="{Binding Priority, Mode=TwoWay}"
                                                  SelectedValuePath="Tag">
                                            <ComboBoxItem Tag="{x:Static models:TicketPriority.Low}" Content="Low" />
                                            <ComboBoxItem Tag="{x:Static models:TicketPriority.Medium}" Content="Medium" />
                                            <ComboBoxItem Tag="{x:Static models:TicketPriority.High}" Content="High" />
                                            <ComboBoxItem Tag="{x:Static models:TicketPriority.Critical}" Content="Critical" />
                                        </ComboBox>
                                    </StackPanel>
                                </UniformGrid>

                                <UniformGrid Grid.Row="4"
                                             Columns="2"
                                             Margin="0,0,0,10">
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Requested Date" FontWeight="SemiBold" />
                                        <DatePicker Margin="0,6,0,0"
                                                    SelectedDate="{Binding RequestedDate, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Assign Worker" FontWeight="SemiBold" />
                                        <ComboBox Margin="0,6,0,0"
                                                  ItemsSource="{Binding Workers}"
                                                  DisplayMemberPath="FullName"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding SelectedWorkerId, Mode=TwoWay}" />
                                    </StackPanel>
                                </UniformGrid>

                                <StackPanel Grid.Row="5"
                                            Margin="0,0,0,10">
                                    <TextBlock Text="Next Status" FontWeight="SemiBold" />
                                    <ComboBox Margin="0,6,0,0"
                                              SelectedValue="{Binding NextStatus, Mode=TwoWay}"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Tag="{x:Static models:TicketStatus.Pending}" Content="Pending" />
                                        <ComboBoxItem Tag="{x:Static models:TicketStatus.Assigned}" Content="Assigned" />
                                        <ComboBoxItem Tag="{x:Static models:TicketStatus.InProgress}" Content="In Progress" />
                                        <ComboBoxItem Tag="{x:Static models:TicketStatus.Resolved}" Content="Resolved" />
                                        <ComboBoxItem Tag="{x:Static models:TicketStatus.Closed}" Content="Closed" />
                                        <ComboBoxItem Tag="{x:Static models:TicketStatus.Canceled}" Content="Canceled" />
                                    </ComboBox>
                                </StackPanel>

                                <UniformGrid Grid.Row="6"
                                             Margin="0,0,0,12"
                                             Columns="4"
                                             Rows="2">
                                    <Button Margin="0,0,8,8"
                                            Padding="10,5"
                                            Command="{Binding CreateCommand}"
                                            Content="Create" />
                                    <Button Margin="0,0,8,8"
                                            Padding="10,5"
                                            Command="{Binding UpdateDetailsCommand}"
                                            Content="Update Details" />
                                    <Button Margin="0,0,8,8"
                                            Padding="10,5"
                                            Command="{Binding AssignWorkerCommand}"
                                            Content="Assign Worker" />
                                    <Button Margin="0,0,0,8"
                                            Padding="10,5"
                                            Command="{Binding UnassignWorkerCommand}"
                                            Content="Unassign Worker" />
                                    <Button Margin="0,0,8,0"
                                            Padding="10,5"
                                            Command="{Binding ChangeStatusCommand}"
                                            Content="Change Status" />
                                    <Button Margin="0,0,8,0"
                                            Padding="10,5"
                                            Command="{Binding CancelCommand}"
                                            Content="Cancel" />
                                    <Button Margin="0,0,8,0"
                                            Padding="10,5"
                                            Command="{Binding DeleteCanceledCommand}"
                                            Content="Delete Canceled" />
                                    <Button Margin="0,0,0,0"
                                            Padding="10,5"
                                            Command="{Binding ResetCommand}"
                                            Content="Reset" />
                                </UniformGrid>

                                <StackPanel Grid.Row="7"
                                            Margin="0,0,0,10">
                                    <Separator Margin="0,0,0,10" />
                                    <TextBlock Text="Audit Trail"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#17324D" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="Review ticket history before deleting canceled records."
                                               Foreground="#5F7184"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <DataGrid Grid.Row="8"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding AuditTrail}"
                                          GridLinesVisibility="Horizontal"
                                          RowHeaderWidth="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="OccurredAtUtc"
                                                            Width="1.2*"
                                                            Binding="{Binding OccurredAtUtc, StringFormat=g}" />
                                        <DataGridTextColumn Header="ChangedBy"
                                                            Width="*"
                                                            Binding="{Binding ChangedBy}" />
                                        <DataGridTextColumn Header="Message"
                                                            Width="2*"
                                                            Binding="{Binding Message}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Map">
                    <Grid Margin="0,14,0,0"
                          DataContext="{Binding MapManagement}">
                        <views:MapView/>
                    </Grid>
                </TabItem>

                <TabItem Header="Reports">
                    <Grid Margin="0,14,0,0"
                          DataContext="{Binding ReportManagement}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="26" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="18"
                                Background="#F7FAFD"
                                BorderBrush="#D9E3EC"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="Ticket Reports"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#17324D" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="View and filter tickets by status, elevator, worker, and date range."
                                                   Foreground="#5F7184"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right"
                                            MinWidth="110"
                                            Padding="14,8"
                                            Margin="12,0,0,0"
                                            Command="{Binding LoadReportsCommand}"
                                            Content="Refresh" />
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,14,0,10"
                                           Text="{Binding StatusMessage}"
                                           Foreground="#2F5D85"
                                           FontWeight="SemiBold" />

                                <DataGrid Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding ReportTicketRows}"
                                          SelectionMode="Single"
                                          GridLinesVisibility="Horizontal"
                                          RowHeaderWidth="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Description"
                                                            Width="1.5*"
                                                            Binding="{Binding Description}" />
                                        <DataGridTextColumn Header="Issue"
                                                            Width="*"
                                                            Binding="{Binding IssueType}" />
                                        <DataGridTextColumn Header="Priority"
                                                            Width="0.9*"
                                                            Binding="{Binding Priority}" />
                                        <DataGridTextColumn Header="Status"
                                                            Width="0.9*"
                                                            Binding="{Binding Status}" />
                                        <DataGridTextColumn Header="Requested"
                                                            Width="1.1*"
                                                            Binding="{Binding RequestedDate, StringFormat=g}" />
                                        <DataGridTextColumn Header="Elevator"
                                                            Width="1.2*"
                                                            Binding="{Binding ElevatorName}" />
                                        <DataGridTextColumn Header="Worker"
                                                            Width="1.2*"
                                                            Binding="{Binding AssignedWorkerName}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="18"
                                Background="#FCFDFE"
                                BorderBrush="#D9E3EC"
                                BorderThickness="1"
                                CornerRadius="14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Filter Controls"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="#17324D" />
                                    <TextBlock Margin="0,4,0,18"
                                               Text="Filter tickets by status, elevator, worker, and date range."
                                               Foreground="#5F7184"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="Status" FontWeight="SemiBold" />
                                    <ComboBox Margin="0,6,0,10"
                                              SelectedValue="{Binding SelectedTicketStatus, Mode=TwoWay}"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Tag="" Content="All" />
                                        <ComboBoxItem Tag="{x:Static models:TicketStatus.Pending}" Content="Pending" />
                                        <ComboBoxItem Tag="{x:Static models:TicketStatus.Assigned}" Content="Assigned" />
                                        <ComboBoxItem Tag="{x:Static models:TicketStatus.InProgress}" Content="In Progress" />
                                        <ComboBoxItem Tag="{x:Static models:TicketStatus.Resolved}" Content="Resolved" />
                                        <ComboBoxItem Tag="{x:Static models:TicketStatus.Closed}" Content="Closed" />
                                    </ComboBox>

                                    <TextBlock Text="Elevator" FontWeight="SemiBold" />
                                    <ComboBox Margin="0,6,0,10"
                                              ItemsSource="{Binding Elevators}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding SelectedElevatorId, Mode=TwoWay}" />

                                    <TextBlock Text="Worker" FontWeight="SemiBold" />
                                    <ComboBox Margin="0,6,0,10"
                                              ItemsSource="{Binding Workers}"
                                              DisplayMemberPath="FullName"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding SelectedWorkerId, Mode=TwoWay}" />

                                    <TextBlock Text="From Date" FontWeight="SemiBold" />
                                    <DatePicker Margin="0,6,0,10"
                                                SelectedDate="{Binding FromDate, Mode=TwoWay}" />

                                    <TextBlock Text="To Date" FontWeight="SemiBold" />
                                    <DatePicker Margin="0,6,0,10"
                                                SelectedDate="{Binding ToDate, Mode=TwoWay}" />

                                    <WrapPanel ItemHeight="40"
                                               ItemWidth="124"
                                               Margin="0,18,0,0">
                                        <Button Margin="0,0,12,12"
                                                Padding="14,8"
                                                Command="{Binding ApplyFiltersCommand}"
                                                Content="Apply Filters" />
                                        <Button Margin="0,0,12,12"
                                                Padding="14,8"
                                                Command="{Binding ResetFiltersCommand}"
                                                Content="Reset Filters" />
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
